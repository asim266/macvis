{
  "name": "macvis",
  "version": "0.1.0",
  "description": "Local-first agentic AI assistant for macOS",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "electron-vite dev --config electron-vite.config.ts",
    "build": "electron-vite build --config electron-vite.config.ts && electron-builder",
    "preview": "electron-vite preview --config electron-vite.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "extends": "./electron-builder.yml"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-react": "^6.0.1",
    "conf": "^15.1.0",
    "electron": "^41.5.0",
    "electron-vite": "^5.0.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.14.0",
    "nanoid": "^5.1.11",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
